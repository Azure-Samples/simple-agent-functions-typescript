{
  "name": "simple-agent-functions-typescript",
  "version": "1.0.0",
  "type": "module",
  "description": "A simple AI agent built with the GitHub Copilot SDK, running as an Azure Function.",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "chat": "npx tsx chat.ts"
  },
  "dependencies": {
    "@azure/functions": "^4.6.0",
    "@azure/identity": "^4.6.0",
    "@github/copilot-sdk": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "main": "dist/src/{index.js,functions/*.js}"
}
